<!DOCTYPE html>
<html lang="fr" class="map">
	<head>
		<meta charset="utf-8"/>
		<title>Tu persistes ↢↣</title>
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<link rel="stylesheet" href="{{meta.baseURL}}style.css">
	</head>
	<body>
		<main >

			{% for column in collections.map %}
				<div>
					<p class="column">Colonne № {{loop.index}}</p>
					{% for item in column %}
						{% if item.word %}
							<p>
								<span>{{item.word}}</span>
								<a href="/{{item.hrefSelf}}.html">↣</a>
							</p>
						{% else  %}
							<p>​</p>

						{% endif %}
					{% endfor %}
				</div>

			{% endfor %}
		</main>
		<footer>
			<a href="{{meta.baseURL}}">Retour</a>
		</footer>

	</body>

</html>