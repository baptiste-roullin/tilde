<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="utf-8"/>
		<title>Génération de formes</title>
		<link rel="stylesheet" href="remarkdown_theme.css"/>
		<link rel="stylesheet" href="style.css"/>
		<link rel="stylesheet" href="dark.css"  media="screen and (prefers-color-scheme: dark)"/>
		<link class="dark-manual" rel="stylesheet" href="dark.css"/>
		<script defer src="./scriptures.js"></script>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">

	</head>
	<body data-dark="false" class="remarkdown h1-underline h2-underline">
		<header>
			<div>
				<h1>Journal visual d'un apprenti en génération de formes.</h1>
				<button class="dark-button">Mode sombre</button>
			</div>
		</header>

		<main>
			{% for post in collections.mergedCollection %}
				{% if post.name %}

					{% if loop.index % 2 %}
						{% set title = "Ceci" %}
					{% else  %}
						{% set title = "Cela" %}
					{% endif %}
				{% else %}
					{% set title = post.data.title %}
				{% endif %}

				<article class="item" style="">
					<div>
						<h2>{{title}}</h2>
						<a href="#{{loop.index}}">⚓</a>
						<p>{{post.date | formatDate }}</p>
					</div>

					<div>
						{% if post.img %}
							<img class="" id="{{loop.index}}" loading="lazy" src="./images/{{post.name}}" >
						{% elif post.vid %}
							<video class="" width="100%" height="auto" controls id="{{loop.index}}" loading="lazy" loop src="./images/{{post.name}}"></video>
						{% else  %}
							{{post.content | safe}}
						{% endif %}

					</div>

				</article>
			{% endfor %}
		</main>
		<footer>
			<h2>Pied de page</h2>
			<div class="text"></div>
		</footer>
	</body>
</html>